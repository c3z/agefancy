{
  "name": "agefancy",
  "version": "1.0.0",
  "description": "Osobista maszyna szyfrowa. Deterministic age keys from an xkcd-style passphrase + 4 rotor dials, ciphertext in 5-letter blocks. 100% client-side. Fork of MarinX/agewasm.",
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
    "preview": "vite preview",
    "format": "prettier --write src/*.html src/*.js src/*.css"
  },
  "keywords": [
    "encryption",
    "age-encryption",
    "enigma",
    "client-side"
  ],
  "author": "c3z (fork of agewasm by Marin Basic, marin-basic.com)",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  },
  "dependencies": {
    "@fontsource/archivo-black": "^5.2.5",
    "@fontsource/ibm-plex-mono": "^5.2.5"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "vite": "^6.1.0"
  }
}
